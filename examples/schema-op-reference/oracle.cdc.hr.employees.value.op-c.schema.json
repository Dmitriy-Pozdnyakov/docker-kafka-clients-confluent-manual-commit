{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Учебный пример ветки oneOf для INSERT (op='c').",
  "description": "Как читать схему: properties = допустимые поля объекта; required = какие поля обязаны присутствовать; additionalProperties=false = лишние поля запрещены.",
  "type": "object",
  "properties": {
    "op": {
      "type": "string",
      "enum": ["c"],
      "description": "Код операции CDC. Здесь фиксированное значение: c (create/insert)."
    },
    "source": {
      "type": "object",
      "description": "Технический блок источника события (позиция в redo + идентификация таблицы).",
      "$comment": "Список required ниже означает: эти поля должны быть в каждом событии независимо от op.",
      "properties": {
        "schema": { "type": "string", "description": "Oracle owner/schema (например HR)." },
        "table": { "type": "string", "description": "Имя таблицы (например EMPLOYEES)." },
        "commit_scn": { "type": "integer", "description": "Commit SCN транзакции." },
        "redo_sequence": { "type": "integer", "description": "Номер redo sequence из archived log." },
        "rs_id": { "type": "string", "description": "Row sequence id из LogMiner." },
        "ssn": { "type": "integer", "description": "SQL sequence number внутри транзакции." },
        "ts_ms": { "type": ["integer", "null"], "description": "Опциональный timestamp события в миллисекундах." }
      },
      "required": ["schema", "table", "commit_scn", "redo_sequence", "rs_id", "ssn"],
      "additionalProperties": false
    },
    "before": {
      "type": "null",
      "description": "Для INSERT 'before' всегда null (строки до вставки не было)."
    },
    "after": {
      "type": "object",
      "description": "Полный row-image после INSERT.",
      "$comment": "required ниже перечисляет non-null колонки таблицы, они должны быть в payload для op='c'.",
      "properties": {
        "EMPLOYEE_ID": { "type": "number", "description": "PK сотрудника." },
        "FIRST_NAME": { "type": ["string", "null"], "description": "Имя (nullable)." },
        "LAST_NAME": { "type": "string", "description": "Фамилия (non-null)." },
        "EMAIL": { "type": ["string", "null"], "description": "Email (nullable)." },
        "HIRE_DATE": { "type": "string", "description": "Дата найма (non-null)." },
        "SALARY": { "type": ["number", "null"], "description": "Зарплата (nullable)." },
        "DEPARTMENT_ID": { "type": ["number", "null"], "description": "ID департамента (nullable)." },
        "CREATED_AT": { "type": "string", "description": "Техническое время создания (non-null)." }
      },
      "required": ["EMPLOYEE_ID", "LAST_NAME", "HIRE_DATE", "CREATED_AT"],
      "additionalProperties": false
    }
  },
  "required": ["op", "source", "before", "after"],
  "additionalProperties": false
}
