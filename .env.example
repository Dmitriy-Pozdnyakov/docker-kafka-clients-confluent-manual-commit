# =========================
# Docker Compose: лимиты ресурсов контейнеров
# =========================
# Память и CPU для one-shot producer Oracle CDC
ORACLE_PRODUCER_SR_MEM_LIMIT=512m
ORACLE_PRODUCER_SR_CPUS=0.50
# Память и CPU для schema build контейнера
ORACLE_SCHEMA_BUILD_MEM_LIMIT=512m
ORACLE_SCHEMA_BUILD_CPUS=0.50
