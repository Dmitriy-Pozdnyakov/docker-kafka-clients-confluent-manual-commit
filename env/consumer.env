BROKER=host.docker.internal:19092,host.docker.internal:19093,host.docker.internal:19094
TOPIC=transactions
GROUP_ID=confluent-manual-group
AUTO_OFFSET_RESET=earliest

# CONSUMER_RUN_MODE: continuous | interval | oneshot
CONSUMER_RUN_MODE=continuous
CONSUMER_INTERVAL_SEC=30
CONSUMER_BATCH_SIZE=100
CONSUMER_BATCH_TIMEOUT_SEC=10

KAFKA_SECURITY_PROTOCOL=PLAINTEXT
SSL_CAFILE=/certs/ca.crt
SSL_CHECK_HOSTNAME=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password
