# =========================
# Oracle: подключение к БД
# =========================
# Эти креды используются producer-ом для LogMiner чтения redo stream.
# Роль: runtime-cdc (не metadata builder).
# Рекомендуемый пользователь: общий C##LOGMINER в сервисе FREE (CDB).
ORACLE_USER=C##LOGMINER
ORACLE_PASSWORD=logminer_pass_123
ORACLE_DSN=host.docker.internal:1521/FREE

# =========================
# Runtime / state (one-shot запуск)
# =========================
# One-shot контейнер: периодичность задается внешним scheduler (cron/flock).
# START_FROM_SCN: пусто = читать с watermark из STATE_FILE.
STATE_FILE=/state/oracle_kafka_state_archivelog_sr_cdc.json
START_FROM_SCN=
VERBOSE=true

# =========================
# Kafka: подключение и безопасность
# =========================
# KAFKA_SECURITY_PROTOCOL: PLAINTEXT | SSL | SASL_PLAINTEXT | SASL_SSL.
# SSL_* и KAFKA_SASL_* используются только в соответствующих режимах безопасности.
KAFKA_TOPIC=oracle.logminer.raw
KAFKA_BROKER=host.docker.internal:19092,host.docker.internal:19093,host.docker.internal:19094
KAFKA_CLIENT_ID=oracle-logminer-archivelog-sr-cdc
KAFKA_FLUSH_TIMEOUT_SEC=30
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
SSL_CAFILE=/certs/ca.crt
SSL_CHECK_HOSTNAME=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password

# =========================
# LogMiner / batch runtime
# =========================
# ARCHIVE_LOG_LIMIT: сколько archived redo логов подключать за one-shot батч.
# USE_NO_ROWID_IN_STMT=true уменьшает привязку к ROWID в SQL_REDO/SQL_UNDO.
ARCHIVE_LOG_LIMIT=3
USE_NO_ROWID_IN_STMT=true
CALL_TIMEOUT_MS=30000
PRODUCE_RETRY_TIMEOUT_SEC=60
PRODUCE_RETRY_POLL_SEC=0.2

# =========================
# Topic routing
# =========================
# TOPIC_PER_TABLE=true: писать в oracle.cdc.<schema>.<table>.
# TOPIC_PER_TABLE=false: писать в единый KAFKA_TOPIC.
TOPIC_PER_TABLE=true
TOPIC_PREFIX=oracle.cdc
TOPIC_SEPARATOR=.

# =========================
# Чтение из v$logmnr_contents
# =========================
# MAX_ROWS_PER_BATCH: верхний лимит строк в батче (с добором целого commit_scn).
# USE_FETCHMANY/FETCHMANY_SIZE: режим и размер выборки курсора.
MAX_ROWS_PER_BATCH=5000
USE_FETCHMANY=true
FETCHMANY_SIZE=1000
LOG_FIRST_N_EVENTS=3

# =========================
# Фильтры объектов Oracle
# =========================
# Фильтры: только CSV-списки
FILTER_SCHEMAS=HR
FILTER_TABLES=EMPLOYEES,DEPARTMENTS

# =========================
# CDC + Schema Registry
# =========================
# CDC_ENVELOPE_ENABLED=true: событие формируется как CDC envelope (op/source/before/after).
# CDC_SUPPORTED_TABLES: whitelist таблиц, для которых включен CDC envelope.
# SCHEMA_DIR: каталог локальных схем внутри контейнера.
# CDC_SQL_PARSER_BACKEND:
# - auto: сначала sqlglot, затем legacy fallback;
# - auto_legacy_first (или legacy_first): сначала legacy, затем sqlglot fallback;
# - legacy: только legacy backend;
# - sqlglot: только sqlglot backend.
CDC_ENVELOPE_ENABLED=true
CDC_SUPPORTED_TABLES=HR.EMPLOYEES,HR.DEPARTMENTS
CDC_KEY_MODE=technical
CDC_PARSE_ERROR_MODE=fail
CDC_SQL_PARSER_BACKEND=auto
SCHEMA_REGISTRY_URL=http://host.docker.internal:18081
SCHEMA_DIR=/app/schemas
# Manual SR mode: схемы должны быть заранее зарегистрированы в Schema Registry.
SCHEMA_AUTO_REGISTER=false
SCHEMA_USE_LATEST_VERSION=true
SCHEMA_NORMALIZE=true
