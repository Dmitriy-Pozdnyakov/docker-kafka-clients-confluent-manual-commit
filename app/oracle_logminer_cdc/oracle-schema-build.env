ORACLE_USER=system
ORACLE_PASSWORD=change_me_oracle_password
ORACLE_DSN=10.20.30.50:1521/XEPDB1

# Таблицы для schema build (CSV SCHEMA.TABLE)
TABLES=HR.EMPLOYEES,HR.DEPARTMENTS
# Альтернатива: путь к файлу с таблицами (по одной в строке)
TABLES_FILE=

# Топик-нейминг
TOPIC_PREFIX=oracle.cdc
TOPIC_SEPARATOR=.

# Куда сохранять schema файлы
SCHEMA_DIR=app/oracle_logminer_cdc/schemas

# Режим ключа: technical | pk
KEY_MODE=technical

# Опции записи файлов:
# - пусто: не перезаписывать
# - любое непустое значение: добавить флаг --overwrite
OVERWRITE=

# Регистрация в Schema Registry (manual pre-deploy шаг):
# - пусто: не регистрировать
# - любое непустое значение: добавить флаг --register-sr
REGISTER_SR=
SCHEMA_REGISTRY_URL=http://10.20.30.40:8081
# Для Basic auth (опционально): user:password
SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO=
