ORACLE_USER=C##LOGMINER
ORACLE_PASSWORD=logminer_pass_123
ORACLE_DSN=host.docker.internal:1521/FREE

# One-shot контейнер: периодичность задается внешним scheduler (cron/flock)
STATE_FILE=/state/oracle_kafka_state_archivelog_sr_cdc.json
START_FROM_SCN=
VERBOSE=true

KAFKA_TOPIC=oracle.logminer.raw
KAFKA_BROKER=host.docker.internal:19092,host.docker.internal:19093,host.docker.internal:19094
KAFKA_CLIENT_ID=oracle-logminer-archivelog-sr-cdc
KAFKA_FLUSH_TIMEOUT_SEC=30
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
SSL_CAFILE=/certs/ca.crt
SSL_CHECK_HOSTNAME=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password

ARCHIVE_LOG_LIMIT=3
USE_NO_ROWID_IN_STMT=true
CALL_TIMEOUT_MS=30000
PRODUCE_RETRY_TIMEOUT_SEC=60
PRODUCE_RETRY_POLL_SEC=0.2

TOPIC_PER_TABLE=true
TOPIC_PREFIX=oracle.cdc
TOPIC_SEPARATOR=.

MAX_ROWS_PER_BATCH=5000
USE_FETCHMANY=true
FETCHMANY_SIZE=1000
LOG_FIRST_N_EVENTS=3

# Фильтры: можно использовать одиночные или списки CSV
FILTER_SCHEMA=
FILTER_TABLE=
FILTER_SCHEMAS=HR
FILTER_TABLES=EMPLOYEES,DEPARTMENTS

# CDC + Schema Registry
CDC_ENVELOPE_ENABLED=true
CDC_SUPPORTED_TABLES=HR.EMPLOYEES,HR.DEPARTMENTS
CDC_KEY_MODE=technical
CDC_PARSE_ERROR_MODE=fail
SCHEMA_REGISTRY_URL=http://host.docker.internal:18081
SCHEMA_DIR=/app/app/oracle_logminer_cdc/schemas
# Manual SR mode: схемы должны быть заранее зарегистрированы в Schema Registry.
SCHEMA_AUTO_REGISTER=false
SCHEMA_USE_LATEST_VERSION=true
SCHEMA_NORMALIZE=true
