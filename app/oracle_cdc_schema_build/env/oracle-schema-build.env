# =========================
# Oracle: подключение к БД
# =========================
# Эти креды используются только schema-builder для чтения metadata таблиц.
# Роль: metadata-build (не runtime LogMiner).
# Для HR.* таблиц подключаемся к PDB сервису FREEPDB1.
ORACLE_USER=system
ORACLE_PASSWORD=Oracle123!
ORACLE_DSN=host.docker.internal:1521/FREEPDB1

# =========================
# Источник списка таблиц
# =========================
# TABLES: CSV список вида SCHEMA.TABLE.
# TABLES_FILE: файл со списком таблиц (по одной в строке), если нужен внешний источник.
# Можно использовать либо TABLES, либо TABLES_FILE.
TABLES=HR.EMPLOYEES,HR.DEPARTMENTS
TABLES_FILE=

# =========================
# Topic naming для subject/topic
# =========================
TOPIC_PREFIX=oracle.cdc
TOPIC_SEPARATOR=.

# =========================
# Локальные schema файлы
# =========================
# SCHEMA_DIR: путь, куда сохраняются сгенерированные key/value JSON schema.
SCHEMA_DIR=/app/schemas

# =========================
# Режим ключа
# =========================
# KEY_MODE: technical | pk
KEY_MODE=technical

# =========================
# Политика перезаписи файлов
# =========================
# OVERWRITE:
# - пусто: не перезаписывать существующие файлы
# - любое непустое значение: добавить флаг --overwrite
OVERWRITE=

# =========================
# Регистрация в Schema Registry
# =========================
# REGISTER_SR:
# - пусто: не регистрировать схемы в SR
# - любое непустое значение: добавить флаг --register-sr
# SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO: опционально, формат user:password
REGISTER_SR=yes
SCHEMA_REGISTRY_URL=http://host.docker.internal:18081
SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO=
